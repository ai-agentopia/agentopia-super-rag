# agentopia-super-rag — knowledge-api local environment
#
# Copy to .env.local and fill in real values.
# In production, these are injected via K8s Secrets (see docs/operations.md).
# Do NOT commit .env.local — it is in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Qdrant vector store (required for real search; leave empty for in-memory fallback)
QDRANT_URL=http://localhost:6333

# Postgres document lifecycle store (required for document provenance tracking)
DATABASE_URL=postgresql://agentopia:agentopia@localhost:5432/agentopia

# OpenRouter embedding API (agentopia-super-rag uses text-embedding-3-small via OpenRouter)
# EMBEDDING_BASE_URL sets the base URL read by both the embedding path and the LLM paths
# (W3a/W3b/W4 features). Default: https://openrouter.ai/api/v1/embeddings
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1/embeddings
EMBEDDING_API_KEY=<your-openrouter-api-key>

# Shared secret for X-Internal-Token auth (bot-config-api → knowledge-api)
# In production this is a strong random string. For local dev any value works.
KNOWLEDGE_API_INTERNAL_TOKEN=local-dev-token

# K8s namespace to read ArgoCD Application CRDs from (bot-scope binding cache)
# Leave empty or unset for local dev — binding cache will start empty gracefully
K8S_NAMESPACE=agentopia

# ── Optional — override defaults ──────────────────────────────────────────────

# EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small
# BINDING_RECONCILE_INTERVAL_SECS=300
# LOG_LEVEL=INFO
# LOG_FORMAT=text    # set to "json" for structured JSON log output
# PORT=8002

# ── Dormant retrieval features (all default-off) ──────────────────────────────
# These env vars activate W-series features that are implemented but NOT approved
# for production use. See docs/evaluation.md for gate evidence.
# No scope should enable these without new evaluation evidence on a real corpus.
#
# LLM_PROXY_URL=
# QUERY_EXPANSION_SCOPES=    # W3a: comma-separated scope names
# HYDE_SCOPES=               # W3b: comma-separated scope names
# RERANK_SCOPES=             # W4: comma-separated scope names
# RERANK_MODEL=openai/gpt-4o-mini
